    "--name/-n (project name)",
    "--framework/-f (express, fastify)",
    "--database/-d (mysql, postgres, mongodb)",
    "--orm/-o (prisma, drizzle, mongoose)",
    "--auth/-a (jwt-auth, none)",
    "--features (additional features)",
    "--git (initialize git repository)",
